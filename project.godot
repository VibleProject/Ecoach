config_version=5

[application]

config/name="ecoach"
run/main_scene="uid://csktyl1mu0oiw"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Global="*uid://bshfwo3nds1l4"

[display]

